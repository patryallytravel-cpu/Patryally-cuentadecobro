# API key de Resend (https://resend.com) - necesaria para el boton "Enviar por correo"
# 1. Crea una cuenta gratis en resend.com
# 2. Ve a API Keys y crea una nueva
# 3. Pega el valor aqui (y en Vercel > Settings > Environment Variables)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxx

# Direccion "From" que envia el correo.
# Mientras no verifiques el dominio patryally.com en Resend, deja el valor de pruebas.
# Cuando verifiques el dominio, cambialo a algo como: Patryally <cuentas@patryally.com>
EMAIL_FROM="Patryally <onboarding@resend.dev>"

# Destinatarios que reciben cada cuenta de cobro (separados por coma, sin espacios extra)
EMAIL_TO=Contabilidad.patryally@outlook.com,Patryallytravel@gmail.com
